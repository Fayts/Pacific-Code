# ============================================================
# Pacific Code — Variables d'environnement
# Copier ce fichier vers .env.local puis renseigner les valeurs.
# ============================================================

# --- Supabase (obligatoire) ---------------------------------
# URL du projet : Dashboard Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE-PROJET.supabase.co
# Clé publique (publishable key sb_publishable_... ou clé anon legacy).
# Cette clé est publique : la sécurité repose sur Row Level Security.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxx

# --- Assistant IA (facultatif) ------------------------------
# Fournisseur : anthropic | openai | google | demo
# "demo" (ou variable absente) active le mode démonstration :
# l'assistant répond avec de vraies données mais sans appel à un LLM.
AI_PROVIDER=demo

# Renseigner UNE clé selon le fournisseur choisi.
# Ces clés restent côté serveur, jamais exposées au navigateur.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Modèle optionnel (sinon un modèle par défaut est choisi par fournisseur)
# AI_MODEL=claude-sonnet-5
